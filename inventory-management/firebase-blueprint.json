{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account properties and permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer demographics and settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "tin": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone", "address", "tin", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles collection"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers collection"
    }
  }
}
