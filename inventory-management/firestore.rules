rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || existing().role == 'Admin');
      allow list: if isSignedIn() && resource.data.id == request.auth.uid;
      allow create: if isSignedIn() && isOwner(userId) && 
                      incoming().keys().hasAll(['id', 'name', 'email', 'role', 'status']) &&
                      incoming().keys().size() == 5 &&
                      incoming().id == request.auth.uid &&
                      incoming().name is string && incoming().name.size() <= 100 &&
                      incoming().email is string && incoming().email.size() <= 100 &&
                      incoming().role == 'Staff' &&
                      incoming().status == 'Active';
      allow update: if isSignedIn() && isOwner(userId) &&
                      incoming().id == existing().id &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email']) &&
                      incoming().name is string && incoming().name.size() <= 100 &&
                      incoming().email is string && incoming().email.size() <= 100;
      allow delete: if false; // Users cannot delete their profile directly
    }

    // --- Customers Collection ---
    match /customers/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && 
                      isValidId(customerId) &&
                      incoming().keys().hasAll(['id', 'name', 'email', 'phone', 'address', 'tin', 'status']) &&
                      incoming().keys().size() == 7 &&
                      incoming().name is string && incoming().name.size() <= 150 &&
                      incoming().email is string && incoming().email.size() <= 150 &&
                      incoming().status == 'Active';
      allow update: if isSignedIn() && 
                      incoming().id == existing().id &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'address', 'tin', 'status']) &&
                      incoming().name is string && incoming().name.size() <= 150;
      allow delete: if false;
    }
  }
}
